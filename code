    /* Add alumni: upload photo to storage then insert row into alumni table.
       This code uses the anon key and a public bucket 'public-assets' (create it in Supabase).
       If your DB schema differs, adjust the insert fields accordingly. */
    async function addAlumni(){
      const name = document.getElementById("name").value.trim();
      const email = document.getElementById("email").value.trim();
      const batch = document.getElementById("batch").value;
      const course = document.getElementById("course").value.trim();
      const category = document.getElementById("category").value;
      const photoInput = document.getElementById("photo");

      if(!name || !email){
        alert("Please provide name and email.");
        return;
      }

      // Basic client-side email format check (server-side validation recommended)
      const emailRegex = /^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$/;
      if(!emailRegex.test(email)){
        alert("Please enter a valid email address.");
        return;
      }

      let photo_url = null;

      // If a file is selected, upload to Supabase Storage public-assets/profiles/
      if(photoInput && photoInput.files && photoInput.files.length > 0){
        const file = photoInput.files[0];
        const timestamp = Date.now();
        const filename = `${timestamp}-${file.name.replaceAll(" ","_")}`;
        try {
          const { data: uploadData, error: uploadError } = await client.storage
            .from('public-assets')
            .upload(`profiles/${filename}`, file, { cacheControl: '3600', upsert: false });

          if(uploadError){
            console.error("Upload error:", uploadError);
            alert("Photo upload failed. Check console.");
            return;
          }

          // Get public URL
          const { publicURL } = client.storage.from('public-assets').getPublicUrl(`profiles/${filename}`);
          photo_url = publicURL;
        } catch(err){
          console.error(err);
          alert("Photo upload failed (exception).");
          return;
        }
      }

      // Insert into alumni table. Adjust column names if your table differs.
      try {
        const insertPayload = {
          name,
          email,
          batch: batch ? Number(batch) : null,
          course,
          category,
          photo_url
        };

        const { data, error } = await client
          .from('alumni')
          .insert([ insertPayload ]);

        if(error){
          console.error("Insert error:", error);
          alert("Failed to add alumni: " + (error.message || JSON.stringify(error)));
          return;
        }

        alert("Alumni Added Successfully!");
        navigate("#/courses");
      } catch(err){
        console.error(err);
        alert("Failed to add alumni (exception).");
      }
    }

