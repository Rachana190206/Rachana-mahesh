    /* KPI graph */
    function drawKpiGraph(){
      const canvas = document.getElementById("kpiCanvas");
      if(!canvas) return;
      const ctx = canvas.getContext("2d");
      const DPR = window.devicePixelRatio || 1;
      const W = canvas.width;
      const H = canvas.height;
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      canvas.style.width = W + "px";
      canvas.style.height = H + "px";
      ctx.scale(DPR, DPR);
      ctx.clearRect(0,0,W,H);

      const labels = ["Active Alumni","New Registrations","Event RSVPs","Donations"];
      const values = [1200,120,320,500000];
      const scaled = values.map((v,i) => i===3 ? v/1000 : v);
      const maxVal = Math.max(...scaled) * 1.12;
      const padding = 48;
      const barWidth = (W - padding*2) / (labels.length*1.6);
      const gap = barWidth * 0.6;
      const baseY = H - 60;

      ctx.strokeStyle = "#e6eefc";
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(padding, baseY);
      ctx.lineTo(W - padding, baseY);
      ctx.stroke();

      labels.forEach((label, idx) => {
        const x = padding + idx*(barWidth + gap);
        const h = (scaled[idx] / maxVal) * (baseY - 80);
        const y = baseY - h;
        const grad = ctx.createLinearGradient(x, y, x, baseY);
        grad.addColorStop(0, idx===0 ? "#7cc6ff" : idx===1 ? "#ffd27a" : idx===2 ? "#9be7c4" : "#ffd6b3");
        grad.addColorStop(1, "#ffffff");
        ctx.fillStyle = grad;
        roundRect(ctx, x, y, barWidth, h, 8, true, false);
        ctx.fillStyle = "#0b3d91";
        ctx.font = "600 13px 'Segoe UI', Roboto, Arial";
        ctx.fillText(label, x, baseY + 18);
        ctx.fillStyle = "#333";
        ctx.font = "700 14px 'Segoe UI', Roboto, Arial";
        const displayVal = idx===3 ? "₹5L" : values[idx];
        ctx.fillText(displayVal, x, y - 8);
      });

      ctx.fillStyle = "#666";
      ctx.font = "13px 'Segoe UI', Roboto, Arial";
      ctx.fillText("Note: Donations scaled for visualization.", padding, 28);
    }

    function roundRect(ctx, x, y, w, h, r, fill, stroke){
      if (typeof stroke === 'undefined') stroke = true;
      if (typeof r === 'undefined') r = 5;
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
      if (fill) ctx.fill();
      if (stroke) ctx.stroke();
    }

